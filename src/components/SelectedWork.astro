---
// Selected Work Section with Horizontal Scroll & Parallax Mask
---

<section id="selected-work" class="h-scroll-section">
  <div class="h-scroll-sticky">
    <div class="section-header fade-in-up">
      <h2 class="section-title">
        <span class="bracket">[</span> Selected Work <span class="bracket">]</span>
      </h2>
      <p>在模型边界与真实价值之间</p>
    </div>

    <div class="h-scroll-container">
      <div class="h-scroll-track" id="h-track">
        
        <!-- Card 1 -->
        <article class="work-card">
          <div class="card-image-container liquid-glass parallax-mask">
            <div class="card-image bg-placeholder inner-img"></div>
          </div>
          <div class="card-content liquid-glass mt-sm">
            <h3>重新理解语言生成</h3>
            <p>Discrete Flow Matching Language Model (UCLA). 探索不依赖传统自回归范式的语言生成路径。</p>
            <div class="hood-details hidden" data-hood>
              <p><strong>Problem:</strong> Coupling strategy efficiency.</p>
              <p><strong>Method:</strong> Optimizing target distributions for smoother flow.</p>
            </div>
          </div>
        </article>

        <!-- Card 2 -->
        <article class="work-card">
          <div class="card-image-container liquid-glass parallax-mask">
            <div class="card-image bg-placeholder inner-img"></div>
          </div>
          <div class="card-content liquid-glass mt-sm">
            <h3>让照片被自然找回</h3>
            <p>AI-Native Photo Album. 基于 CLIP 和自然语言搜索的下一代相册体验。</p>
            <div class="hood-details hidden" data-hood>
              <p><strong>Trade-off:</strong> Latency vs. Embedding precision.</p>
              <p><strong>Constraint:</strong> Client-side storage limitations.</p>
            </div>
          </div>
        </article>

        <!-- Card 3 -->
        <article class="work-card">
          <div class="card-image-container liquid-glass parallax-mask">
            <div class="card-image bg-placeholder inner-img"></div>
          </div>
          <div class="card-content liquid-glass mt-sm">
            <h3>让先进模型走向可用</h3>
            <p>并行视频采样与流匹配加速 (ZJU). 解决生成模型的工程化与成本瓶颈。</p>
            <div class="hood-details hidden" data-hood>
              <p><strong>Focus:</strong> Inference speed optimization without degrading FID.</p>
            </div>
          </div>
        </article>

        <!-- Card 4 -->
        <article class="work-card">
          <div class="card-image-container liquid-glass parallax-mask">
            <div class="card-image bg-placeholder inner-img"></div>
          </div>
          <div class="card-content liquid-glass mt-sm">
            <h3>建立可靠评估方式</h3>
            <p>Continual Learning of Agent Benchmark (NUS). 定义如何测量智能体的持续进化能力。</p>
            <div class="hood-details hidden" data-hood>
              <p><strong>Framework:</strong> Multi-environment sequential tasks avoiding catastrophic forgetting.</p>
            </div>
          </div>
        </article>

      </div>
    </div>
  </div>
</section>

<style>
  /* 
    通过增加 400vh 的高度，让横向滚动的距离与真实滑动的像素数接近 1:1，
    这样就不会有“竖滑很慢横滚极快”的割裂感。
  */
  @media (min-width: 1024px) {
    .h-scroll-section {
      height: 400vh; 
      padding-block: 0;
      position: relative;
    }

    .h-scroll-sticky {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-left: var(--space-md);
    }

    .h-scroll-container {
      width: 100%;
      overflow: visible; /* Changed to visible so shadows aren't clipped */
    }

    .h-scroll-track {
      display: flex;
      gap: var(--space-lg);
      padding-right: var(--space-xl);
      padding-bottom: var(--space-xl); /* Leave room for shadow/hover */
      width: max-content;
      will-change: transform;
    }
  }

  @media (max-width: 1023px) {
    .h-scroll-section {
      padding-block: var(--space-xl);
    }
    .h-scroll-track {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }
  }

  .section-header {
    margin-bottom: var(--space-md);
    padding-left: var(--space-xs);
  }

  .section-title {
    display: inline-block;
    margin-bottom: 0.5rem;
    font-size: clamp(2.5rem, 4vw, 4rem);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Parallax Brackets for Title */
  .bracket {
    font-weight: 300;
    color: var(--color-text-muted);
    transition: transform 0.8s var(--ease-spring);
    display: inline-block;
  }

  /* When scrolling active, the JS will add a class to spread the brackets */
  .h-scroll-sticky.scrolling-active .bracket:first-child {
    transform: translateX(-15px);
  }
  .h-scroll-sticky.scrolling-active .bracket:last-child {
    transform: translateX(15px);
  }

  /* 拆分后的卡片，图片和内容分离成两块玻璃 */
  .work-card {
    width: clamp(400px, 40vw, 600px); /* 响应式宽度 */
    height: clamp(550px, 70vh, 800px); /* 响应式高度 */
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .card-image-container {
    flex: 0 0 65%; /* 图片占大部分 */
    position: relative;
    overflow: hidden;
    transition: transform var(--transition-bounce), box-shadow var(--transition-fast);
  }

  /* Parallax Mask Magic */
  /* The container acts as a mask (clip-path). The inner image is slightly larger. */
  .parallax-mask {
    clip-path: inset(0% 0% 0% 0%);
    transition: clip-path 0.5s ease-out, transform var(--transition-bounce), box-shadow var(--transition-fast);
  }

  .inner-img {
    width: 110%;
    height: 110%;
    position: absolute;
    top: -5%;
    left: -5%;
    transform: scale(1);
    transition: transform 0.5s ease-out;
  }

  .work-card:hover .card-image-container {
    transform: translateY(-8px);
    clip-path: inset(2% 2% 2% 2%); /* 窗口稍微收缩，产生视差遮罩感 */
    box-shadow: 
      inset 0 1px 1px var(--color-glass-highlight),
      inset 0 0 0 1px var(--color-glass-edge),
      0 12px 24px var(--color-glass-shadow),
      0 24px 48px var(--color-glass-shadow-deep);
  }

  .work-card:hover .inner-img {
    transform: scale(0.95); /* 图片本体不仅不缩小，反而相对外框变大（反向缩放） */
  }

  @media (max-width: 1023px) {
    .work-card {
      width: 100%;
      min-width: unset;
      height: auto;
      min-height: 400px;
    }
    .card-image-container {
      height: 300px;
    }
  }

  .card-content {
    padding: var(--space-md);
    flex: 1; 
    display: flex;
    flex-direction: column;
    overflow: hidden; 
    transition: transform var(--transition-bounce);
  }

  .work-card:hover .card-content {
    transform: translateY(-4px);
  }

  .card-content h3 {
    margin-bottom: 0.5rem;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
  }

  .card-content p {
    font-size: 1.05rem;
  }

  .hidden {
    display: none;
  }

  :global(body[data-view="detail"]) .hood-details {
    display: block;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px dashed var(--color-text-muted);
    font-family: monospace;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>

<script>
  // Smoother Horizontal Scroll logic + Parallax
  const section = document.querySelector('.h-scroll-section') as HTMLElement;
  const sticky = document.querySelector('.h-scroll-sticky') as HTMLElement;
  const track = document.getElementById('h-track') as HTMLElement;

  if (section && track && window.innerWidth >= 1024) {
    let currentX = 0;
    let targetX = 0;
    let isAnimating = false;

    const animate = () => {
      // Lerp function: move 8% of the remaining distance per frame
      currentX += (targetX - currentX) * 0.08;
      
      if (Math.abs(targetX - currentX) > 0.1) {
        track.style.transform = `translate3d(${-currentX}px, 0, 0)`;
        
        // Also apply a very slight skew based on scroll velocity for organic feel
        const velocity = targetX - currentX;
        const skew = Math.max(-2, Math.min(2, velocity * 0.01));
        const cards = track.querySelectorAll('.work-card');
        cards.forEach(card => {
          (card as HTMLElement).style.transform = `skewX(${skew}deg)`;
        });

        requestAnimationFrame(animate);
      } else {
        isAnimating = false;
        // Reset skew when stopped
        track.querySelectorAll('.work-card').forEach(card => {
          (card as HTMLElement).style.transform = `skewX(0deg)`;
        });
      }
    };

    window.addEventListener('scroll', () => {
      const rect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight;
      
      const scrollableDistance = rect.height - viewportHeight;
      let progress = -rect.top / scrollableDistance;
      
      // Trigger active state for brackets animation
      if (progress > 0 && progress < 1) {
        sticky.classList.add('scrolling-active');
      } else {
        sticky.classList.remove('scrolling-active');
      }

      progress = Math.max(0, Math.min(1, progress));
      
      const maxScroll = track.scrollWidth - window.innerWidth + 150; // padding
      targetX = progress * maxScroll;
      
      if (!isAnimating) {
        isAnimating = true;
        requestAnimationFrame(animate);
      }
    }, { passive: true });
  }
</script>
