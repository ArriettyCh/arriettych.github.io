---
// Selected Work Section with Horizontal Scroll & Parallax Mask
---

<section id="selected-work" class="h-scroll-section">
  <div class="section-layout">
    <div class="section-sidebar">
      <div class="sticky-title fade-in-up">
        <h2 class="section-title">Selected Work</h2>
        <p>在模型边界与真实价值之间</p>
      </div>
    </div>

    <div class="section-content">
      <div class="h-scroll-container">
        <div class="h-scroll-track" id="h-track">
          <article class="work-card" data-tone="work-research">
            <div class="work-card-inner liquid-glass">
              <div class="card-image-container parallax-mask">
                <div class="card-image bg-placeholder inner-img"></div>
              </div>
              <div class="card-content">
                <h3>重新理解语言生成</h3>
                <p>Discrete Flow Matching Language Model (UCLA). 探索不依赖传统自回归范式的语言生成路径。</p>
                <div class="hood-details hidden" data-hood>
                  <p><strong>Problem:</strong> Coupling strategy efficiency.</p>
                  <p><strong>Method:</strong> Optimizing target distributions for smoother flow.</p>
                </div>
              </div>
            </div>
          </article>

          <article class="work-card" data-tone="work-product">
            <div class="work-card-inner liquid-glass">
              <div class="card-image-container parallax-mask">
                <div class="card-image bg-placeholder inner-img"></div>
              </div>
              <div class="card-content">
                <h3>让照片被自然找回</h3>
                <p>AI-Native Photo Album. 基于 CLIP 和自然语言搜索的下一代相册体验。</p>
                <div class="hood-details hidden" data-hood>
                  <p><strong>Trade-off:</strong> Latency vs. Embedding precision.</p>
                  <p><strong>Constraint:</strong> Client-side storage limitations.</p>
                </div>
              </div>
            </div>
          </article>

          <article class="work-card" data-tone="work-systems">
            <div class="work-card-inner liquid-glass">
              <div class="card-image-container parallax-mask">
                <div class="card-image bg-placeholder inner-img"></div>
              </div>
              <div class="card-content">
                <h3>让先进模型走向可用</h3>
                <p>并行视频采样与流匹配加速 (ZJU). 解决生成模型的工程化与成本瓶颈。</p>
                <div class="hood-details hidden" data-hood>
                  <p><strong>Focus:</strong> Inference speed optimization without degrading FID.</p>
                </div>
              </div>
            </div>
          </article>

          <article class="work-card" data-tone="work-benchmark">
            <div class="work-card-inner liquid-glass">
              <div class="card-image-container parallax-mask">
                <div class="card-image bg-placeholder inner-img"></div>
              </div>
              <div class="card-content">
                <h3>建立可靠评估方式</h3>
                <p>Continual Learning of Agent Benchmark (NUS). 定义如何测量智能体的持续进化能力。</p>
                <div class="hood-details hidden" data-hood>
                  <p><strong>Framework:</strong> Multi-environment sequential tasks avoiding catastrophic forgetting.</p>
                </div>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 1024px) {
    .h-scroll-section {
      height: 220vh;
      padding-block: 0;
      position: relative;
    }

    .section-layout {
      position: sticky;
      top: var(--header-compact-height);
      min-height: calc(100dvh - var(--header-compact-height));
      display: grid;
      grid-template-columns: 300px minmax(0, 1fr);
      gap: var(--space-xl);
      align-items: start;
      padding-block: var(--space-lg) var(--space-md);
    }

    .sticky-title {
      position: sticky;
      top: calc(var(--header-height) + var(--space-xl));
    }

    .section-content {
      min-width: 0;
      display: flex;
      align-items: center;
      padding-top: var(--space-xl);
    }

    .h-scroll-container {
      width: 100%;
      overflow: hidden;
    }

    .h-scroll-track {
      display: flex;
      gap: var(--space-lg);
      padding-right: var(--space-xl);
      padding-bottom: var(--space-xl);
      width: max-content;
      will-change: transform;
    }
  }

  .section-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (max-width: 1023px) {
    .h-scroll-section {
      padding-block: var(--space-lg);
    }

    .h-scroll-track {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }
  }

  .section-title {
    margin-bottom: 0.5rem;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1.1;
  }

  .work-card {
    --card-accent: var(--tone-solid, var(--content-tone-default));
    width: clamp(400px, 40vw, 600px);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .card-image-container {
    height: 350px;
    position: relative;
    overflow: hidden;
  }

  .parallax-mask {
    clip-path: inset(0% 0% 0% 0%);
    transition: clip-path 0.5s ease-out;
  }

  .inner-img {
    width: 110%;
    height: 110%;
    position: absolute;
    top: -5%;
    left: -5%;
    transform: scale(1);
    transition: transform 0.5s ease-out;
  }

  .card-image {
    width: 100%;
    height: 100%;
  }

  .work-card:hover .card-image-container {
    clip-path: inset(2% 2% 2% 2%);
  }

  .work-card:hover .inner-img {
    transform: scale(0.95);
  }

  @media (max-width: 1023px) {
    .work-card {
      width: 100%;
      min-width: unset;
    }

    .card-image-container {
      height: 300px;
    }
  }

  .card-content {
    padding: var(--space-md);
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .work-card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: transform var(--transition-bounce), box-shadow var(--transition-fast);
  }

  .work-card:hover .work-card-inner {
    transform: translateY(-8px);
    box-shadow:
      inset 0 1px 1px var(--color-glass-highlight),
      inset 0 0 0 1px var(--color-glass-edge),
      0 12px 24px var(--color-glass-shadow),
      0 24px 48px color-mix(in srgb, var(--card-accent) 16%, var(--color-glass-shadow-deep));
  }

  .card-content h3 {
    margin-bottom: 0.5rem;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    color: var(--tone-strong);
  }

  .card-content p {
    font-size: 1.05rem;
    color: var(--tone-muted);
  }

  .hidden {
    display: none;
  }

  :global(body[data-view="detail"]) .hood-details {
    display: block;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px dashed var(--tone-border);
    font-family: monospace;
    font-size: 0.85rem;
    color: var(--tone-muted);
  }
</style>

<script>
  const section = document.querySelector('.h-scroll-section') as HTMLElement | null;
  const track = document.getElementById('h-track') as HTMLElement | null;
  const trackContainer = section?.querySelector('.h-scroll-container') as HTMLElement | null;

  if (section && track && trackContainer) {
    let currentX = 0;
    let targetX = 0;
    let isAnimating = false;
    const cards = Array.from(track.querySelectorAll('.work-card')) as HTMLElement[];

    const resetTrack = () => {
      currentX = 0;
      targetX = 0;
      track.style.transform = 'translate3d(0, 0, 0)';
      cards.forEach((card) => {
        card.style.transform = 'skewX(0deg)';
      });
    };

    const animate = () => {
      currentX += (targetX - currentX) * 0.08;

      if (Math.abs(targetX - currentX) > 0.1) {
        track.style.transform = `translate3d(${-currentX}px, 0, 0)`;

        const velocity = targetX - currentX;
        const skew = Math.max(-2, Math.min(2, velocity * 0.01));
        cards.forEach((card) => {
          card.style.transform = `skewX(${skew}deg)`;
        });

        requestAnimationFrame(animate);
      } else {
        currentX = targetX;
        track.style.transform = `translate3d(${-currentX}px, 0, 0)`;
        isAnimating = false;
        cards.forEach((card) => {
          card.style.transform = 'skewX(0deg)';
        });
      }
    };

    const handleScroll = () => {
      if (window.innerWidth < 1024) {
        resetTrack();
        return;
      }

      const rect = section.getBoundingClientRect();
      const scrollableDistance = Math.max(rect.height - window.innerHeight, 1);
      const progress = -rect.top / scrollableDistance;
      const clampedProgress = Math.max(0, Math.min(1, progress));
      const maxScroll = Math.max(track.scrollWidth - trackContainer.clientWidth, 0);

      targetX = clampedProgress * maxScroll;

      if (!isAnimating) {
        isAnimating = true;
        requestAnimationFrame(animate);
      }
    };

    handleScroll();
    window.addEventListener('scroll', handleScroll, { passive: true });
    window.addEventListener('resize', handleScroll);
  }
</script>
