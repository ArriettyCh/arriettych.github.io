---
interface Props {
  title?: string;
  sectionId?: string;
}

const {
  title = 'MOUNTAIN OF SIGNALS',
  sectionId = 'hero',
} = Astro.props;
---

<section
  id={sectionId}
  class="signal-mountain-hero"
  data-signal-mountain-demo
  data-title={title}
>
  <div class="signal-mountain-hero__sticky" data-signal-mountain-stage>
    <h1 class="signal-mountain-hero__sr">{title}</h1>
    <p class="signal-mountain-hero__sr">
      A glowing signal mountain built from ASCII characters. Scroll to raise the title from behind
      the ridge and move the pointer to disturb the particles.
    </p>

    <canvas class="signal-mountain-hero__canvas" data-signal-mountain-canvas aria-hidden="true"></canvas>
  </div>
</section>

<script>
  import initSignalMountainDemo from '../scripts/signal-mountain-demo.js';

  initSignalMountainDemo();
</script>

<style>
  .signal-mountain-hero {
    --signal-mountain-color: #fff;
    position: relative;
    display: block;
    flex: 0 0 auto;
    isolation: isolate;
    width: 100vw;
    min-width: 100vw;
    max-width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding: 0;
    min-height: 240svh;
    background-color: #000;
    overflow: clip;
  }

  .signal-mountain-hero__sticky {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    height: 100svh;
    min-height: 100svh;
    display: block;
    overflow: clip;
    background-color: #000;
  }

  .signal-mountain-hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
    image-rendering: crisp-edges;
    z-index: 0;
    filter: none;
    opacity: 1;
  }

  .signal-mountain-hero__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .signal-mountain-hero__canvas {
      filter: none;
    }
  }
</style>
