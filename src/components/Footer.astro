---
// Footer Component
---

<footer id="contact" class="footer">
  <div class="footer-inner flex justify-between items-center">
    <div class="footer-left flex items-center gap-md">
      <div class="copyright">
        © {new Date().getFullYear()} Arriettych.
      </div>
      <p class="footer-slogan">Let's build something truly valuable.</p>
    </div>
    
    <div class="contact-links flex gap-md">
      <a href="mailto:your@email.com" class="footer-link">Email</a>
      <a href="https://github.com/arriettych" target="_blank" class="footer-link">GitHub</a>
      <a href="#" class="footer-link">LinkedIn</a>
      <a href="#" class="footer-link">Resume</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    width: 100%;
    height: var(--header-compact-height);
    padding: 0 var(--space-md);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    background: transparent;
  }

  .footer-inner {
    width: 100%;
  }

  .copyright {
    font-size: 0.85rem;
    font-weight: var(--font-weight-ui);
  }

  .footer-slogan {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .contact-links {
    display: flex;
  }

  .footer-link {
    font-size: 0.85rem;
    font-weight: var(--font-weight-ui);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .footer {
      height: auto;
      padding: var(--space-sm) var(--space-md);
    }
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .footer-slogan {
      display: none; /* Hide slogan on mobile to save space */
    }
  }
</style>
