---
// Header component
---

<header class="header liquid-glass" id="main-header">
  <div class="header-inner">
    <div class="logo">
      <a href="#">ARRIETTYCH</a>
    </div>

    <nav class="section-nav" aria-label="页面导航">
      <a href="#selected-work" data-target="selected-work">Selected Work</a>
      <a href="#beyond-work" data-target="beyond-work">Beyond Work</a>
      <a href="#signals" data-target="signals">Signals</a>
      <a href="#now-next" data-target="now-next">Now &amp; Next</a>
    </nav>

    <div class="header-actions">
      <a href="#contact" class="contact-btn pill liquid-glass">Contact</a>
      <button class="under-the-hood pill liquid-glass" id="geek-toggle">Under the Hood</button>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    z-index: 100;
    padding: 0 var(--space-md);
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--color-glass-border);
    transition: height var(--transition-smooth), padding var(--transition-smooth);
  }

  .header.compact {
    height: var(--header-compact-height);
  }

  .header-inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .logo a {
    font-weight: 600;
    letter-spacing: 0.05em;
    font-size: 1.1rem;
    transition: font-size var(--transition-smooth);
  }

  .logo,
  .header-actions {
    flex-shrink: 0;
  }

  .header.compact .logo a {
    font-size: 1rem;
  }

  .section-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.8rem, 1.4vw, 1.35rem);
    flex: 1;
    min-width: 0;
  }

  .section-nav a {
    font-size: clamp(0.64rem, 0.58rem + 0.22vw, 0.72rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .section-nav a:hover,
  .section-nav a[data-state='active'] {
    color: var(--color-text);
  }

  .header.compact .section-nav a {
    font-size: 0.68rem;
  }

  .header-actions {
    display: flex;
    gap: var(--space-sm);
  }

  .contact-btn, .under-the-hood {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    color: var(--color-text);
  }

  .contact-btn:hover, .under-the-hood:hover {
    background: var(--color-text);
    color: var(--color-bg);
  }

  @media (max-width: 1024px) {
    .section-nav {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('geek-toggle');
  toggle?.addEventListener('click', () => {
    const isDetail = document.body.getAttribute('data-view') === 'detail';
    document.body.setAttribute('data-view', isDetail ? 'default' : 'detail');
    toggle.textContent = isDetail ? 'Under the Hood' : 'Exit Hood';
  });

  const header = document.getElementById('main-header');
  const sectionLinks = Array.from(document.querySelectorAll('.section-nav a')) as HTMLAnchorElement[];
  const trackedSections = sectionLinks
    .map((link) => {
      const id = link.dataset.target;
      const section = id ? document.getElementById(id) : null;
      return { link, section };
    })
    .filter((item): item is { link: HTMLAnchorElement; section: HTMLElement } => Boolean(item.section));

  const setHeaderState = () => {
    if (!header) {
      return;
    }

    if (window.scrollY > 100) {
      header.classList.add('compact');
    } else {
      header.classList.remove('compact');
    }
  };

  const updateSectionNav = () => {
    if (!trackedSections.length) {
      return;
    }

    const marker = window.scrollY + window.innerHeight * 0.42;
    let activeId = trackedSections[0].section.id;

    trackedSections.forEach(({ section }) => {
      if (marker >= section.offsetTop) {
        activeId = section.id;
      }
    });

    trackedSections.forEach(({ link, section }) => {
      const isActive = section.id === activeId;
      link.dataset.state = isActive ? 'active' : 'inactive';

      if (isActive) {
        link.setAttribute('aria-current', 'location');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  };

  const handleScroll = () => {
    setHeaderState();
    updateSectionNav();
  };

  handleScroll();
  window.addEventListener('scroll', handleScroll, { passive: true });
  window.addEventListener('resize', handleScroll);
</script>
