---
// Header component
---

<header class="header liquid-glass" id="main-header">
  <div class="header-inner">
    <div class="logo">
      <a href="#">ARRIETTYCH</a>
    </div>

    <nav class="section-nav" aria-label="页面导航">
      <a href="#selected-work" data-target="selected-work">Selected Work</a>
      <a href="#beyond-work" data-target="beyond-work">Beyond Work</a>
      <a href="#signals" data-target="signals">Signals</a>
      <a href="#now-next" data-target="now-next">Now &amp; Next</a>
    </nav>

    <div class="header-actions">
      <a href="#contact" class="contact-link">contact()</a>
    </div>
  </div>
</header>

<style>
  .header {
    --header-content-scale: 1;
    --header-content-shift-y: 0px;
    --glass-edge-background: var(--glass-edge-background-bottom-only);
    --glass-edge-mask: var(--glass-edge-mask-bottom-only);
    --glass-sheen-background: var(--glass-sheen-background-bottom-only);
    --glass-sheen-mask: var(--glass-sheen-mask-bottom-only);
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    z-index: 100;
    padding: 0 var(--space-md);
    display: flex;
    align-items: center;
    transition: height var(--transition-smooth), padding var(--transition-smooth);
  }

  .header.compact {
    height: var(--header-compact-height);
    --header-content-scale: 0.92;
    --header-content-shift-y: -0.5px;
  }

  .header-inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .logo a {
    display: inline-block;
    font-weight: 500;
    letter-spacing: 0.05em;
    font-size: 1.1rem;
    will-change: transform;
  }

  .logo,
  .header-actions {
    flex-shrink: 0;
  }

  .section-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.92rem, 1.55vw, 1.5rem);
    flex: 1;
    min-width: 0;
  }

  .section-nav a {
    font-size: clamp(0.64rem, 0.58rem + 0.22vw, 0.72rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--color-text-muted);
  }

  .logo a,
  .section-nav a,
  .contact-link {
    transform-origin: center;
    transform: translateY(var(--header-content-shift-y)) scale(var(--header-content-scale));
    transition: transform var(--transition-smooth), color var(--transition-fast);
  }

  .section-nav a:hover,
  .section-nav a[data-state='active'],
  .contact-link:hover {
    color: var(--color-text);
  }

  .header-actions {
    display: flex;
    gap: var(--space-sm);
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: clamp(0.64rem, 0.58rem + 0.2vw, 0.72rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: none;
    white-space: nowrap;
    color: var(--color-text-muted);
    font-variant-ligatures: none;
  }

  @media (max-width: 1024px) {
    .section-nav {
      display: none;
    }
  }
</style>

<script>
  const header = document.getElementById('main-header');
  const sectionLinks = Array.from(document.querySelectorAll('.section-nav a')) as HTMLAnchorElement[];
  const trackedSections = sectionLinks
    .map((link) => {
      const id = link.dataset.target;
      const section = id ? document.getElementById(id) : null;
      return { link, section };
    })
    .filter((item): item is { link: HTMLAnchorElement; section: HTMLElement } => Boolean(item.section));

  const setHeaderState = () => {
    if (!header) {
      return;
    }

    if (window.scrollY > 100) {
      header.classList.add('compact');
    } else {
      header.classList.remove('compact');
    }
  };

  const updateSectionNav = () => {
    if (!trackedSections.length) {
      return;
    }

    const marker = window.scrollY + window.innerHeight * 0.42;
    let activeId = trackedSections[0].section.id;

    trackedSections.forEach(({ section }) => {
      if (marker >= section.offsetTop) {
        activeId = section.id;
      }
    });

    trackedSections.forEach(({ link, section }) => {
      const isActive = section.id === activeId;
      link.dataset.state = isActive ? 'active' : 'inactive';

      if (isActive) {
        link.setAttribute('aria-current', 'location');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  };

  const handleScroll = () => {
    setHeaderState();
    updateSectionNav();
  };

  handleScroll();
  window.addEventListener('scroll', handleScroll, { passive: true });
  window.addEventListener('resize', handleScroll);
</script>
